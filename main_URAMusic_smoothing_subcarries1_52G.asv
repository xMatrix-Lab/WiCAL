clc; clear; close all;  

xx = 1.97:-0.2:0.17;
yy = 2:-0.2:-2;
zz = 2;

[X,Y,Z] = meshgrid(xx,yy,zz);

[azimuth,elevation,r] = cart2sph(X-0.97,Y,Z);
theta_gt = 90-rot90(elevation.',2)/pi*180;
phi_gt = rot90(azimuth,1)/pi*180;

figure 
heatmap(theta_gt)
set(gcf,'Position',[800,100,900,400])
title('theta');

figure 
heatmap(phi_gt)
set(gcf,'Position',[800,600,900,400])
title('phi');

% 定义列区间（顺序必须和原来一致）
colRanges = {
    8:11,   % 
    4:7,    %
    1:3,    % 
    18:21,  %
    14:17,  % 
    12:13   %
};

theta_vecs = cell(1,6);
phi_vecs   = cell(1,6);

for i = 1:6
    cols = colRanges{i};

    % theta
    theta_tmp = rot90(flipud(theta_gt(:, cols)), 1);
    theta_vecs{i} = theta_tmp(:);

    % phi
    phi_tmp = rot90(flipud(phi_gt(:, cols)), 1);
    phi_vecs{i} = phi_tmp(:);
end

% theta_phi_gt 
theta_phi_gt = [
    theta_vecs{1}, phi_vecs{1};
    theta_vecs{2}, phi_vecs{2};
    theta_vecs{3}, phi_vecs{3};
    theta_vecs{4}, phi_vecs{4};
    theta_vecs{5}, phi_vecs{5};
    theta_vecs{6}, phi_vecs{6}
];
% save('.\data\test.2024.9.5\theta_phi_gt.mat', 'theta_phi_gt');
%%  % Data used for calibaration
read_root_path = '.\data\test.2024.9.5\'; 
files1 = dir([char(strcat(read_root_path)), '21_1.1.dat']); 

mark_p_coloc = zeros(210,2);
mark_p_MUSIC_ss = zeros(210,2);
mark_p_MUSIC_ss_non = zeros(210,2);
mark_peak_SPICE  = zeros(210,2);
mark_peak_SPICE_N = zeros(210,2);
mark_p_MUSIC_imusic_non = zeros(210,2);
mark_p_MUSIC_imusic = zeros(210,2);
mark_p_MUSIC_non_music = zeros(210,2);
mark_p_MUSIC_music = zeros(210,2);

tic
for i = 1:5    % 1-190 21-1.1.dat  ,  191-210 21_1-6.dat  202
    disp(i)
    tic
    files_1 = dir([char(strcat(read_root_path)), num2str(i), '_1.dat']);  % 带估计数据 
    %% data loader ： 输出最原始的csi数据
    disp("1. Is loading...");
    [csi_all] = data_loader(read_root_path,files_1);
    %% 初始相位：输出12天线依次初始的参数，维度[3*30]，用于CSI数据校准 
    if i >= 191
        files1 = dir([char(strcat(read_root_path)), '21_1.2.dat']);  % 校准用数据  
    end
    disp("2. Is computing init_phase_dif...");
    init_phase_cumulant = init_antenna_subcarrier_phase_dif(read_root_path,files1); % 包含了 天线线长 和 初始相位差。6*3*30
    %% 多包获取与校准
    disp("3. Is calibrating...");
    temp = 1;
    cali_num = 0;
    for pp = 300 : 20 :500
        %% data calibration ： 输入原始csi，输出校准后的csi（包括：天线初始相位差、初始线路相位差、包间采样相位差）
        csi_cal = data_calibration(csi_all{pp},csi_all{pp+1000},csi_all{pp+2000},csi_all{pp+3000},csi_all{pp+4000},csi_all{pp+5000},init_phase_cumulant); % 1.去初始相位
        if csi_cal == 0
            cali_num = cali_num+1;
            continue
        end
        csi_trace_real{temp,:} = csi_cal;
        temp = temp + 1;
    end
    %% 
    Fc = (5.2e9+5.18e9)/2;  
    c = 3e8;
    wavelength = c/Fc;  
    d = wavelength/(1+sind(60));   
    Mx = 3; 
    My = 4; 
    
    N = 30;   
    sub_freq_delta_ = 312.5e3;
    sub_freq_delta = sub_freq_delta_*4; % kHz  
    m0=-58:4:58;
    num_packets = 20;
    
    theta_vec = 0:0.5:90;     % 俯仰角  
    phi_vec = -180:0.5:180;   % 方位角  
    theta_vec_spice=0:1:90;  
    phi_vec_spice = -180:1:180;

    Q = length(theta_vec)*length(phi_vec);
    B = sub_freq_delta*N; 
    ToF = 1/(2*B);
    d_res = ToF*c;
    tau_vec = (1:1:20)*(d_res/10/c);
    
    [csi_y_N] = cook_csi(csi_trace_real, Mx, My, N);

    R = zeros(30,Mx*My,Mx*My);
    for kk=1:30
        R(kk,:,:) = csi_y_N(kk:30:end,:)*csi_y_N(kk:30:end,:)'/size(csi_y_N, 2);
    end
    Ry_N = squeeze(mean(R,1));


    csi_y = csi_y_N(15:30:end,:);
    if ndims(csi_y) == 3
            [xx,yy] = size(squeeze(csi_y(1,:,:)));
            Ry_all = zeros(P,xx,xx);
            for p = 1:P
                csi_y_ = squeeze(csi_y(p,:,:));
                Ry_all(p,:,:) = (csi_y_ * csi_y_')/size(csi_y_,2);  
            end
            Ry = squeeze(sum(Ry_all,1))./size(Ry_all, 1);
    else
        Ry = (csi_y * csi_y')/size(csi_y, 2); 
    end
    Rx1 = Ry; 

    smoothed_csi1 = smooth_csi_y(csi_y, Mx, My, 1);
    P = size(smoothed_csi1,1);
    if ndims(smoothed_csi1) == 3
        [xx,yy] = size(squeeze(smoothed_csi1(1,:,:)));
        Ry_all = zeros(P,xx,xx);
        for p = 1:P
            smoothed_csi_y_ = squeeze(smoothed_csi1(p,:,:));
            Ry_all(p,:,:) = (smoothed_csi_y_ * smoothed_csi_y_')/size(smoothed_csi_y_,2); 
        end
        Ry_ss1 = squeeze(sum(Ry_all,1))./size(Ry_all, 1);
    end

    theta_in = [17.7]/180*pi;      % 此算法在theta角度越大时越不准确。因为虚拟线阵时kr受到theta角度值影响，越来越小。
    phi_in   = [-90]/180*pi;  
    l_in     = [2];                % fen  
    source_num = length(theta_in); 
    tau = l_in/c;
    Coherent_signal_flag = 1;  % 0 非相干，1 相干 
    csi_trace_ = OFDM_data_URA_generation(phi_in, theta_in, l_in, d, wavelength, Fc, sub_freq_delta_, m0, Mx, My, N, num_packets, Coherent_signal_flag);
    % 去斜
    exsample_csi = csi_trace_{1};

    % CS
    % [p_SR] = URA_sparse_reconstruction(csi_y, Mx, My, d, wavelength, theta_vec,phi_vec);
%     %
    SubCarrInd = m0;
%     [p_MUSIC_ss] = URA_ss_wfh(csi_trace_real, Mx, My, Fc,sub_freq_delta_,d, theta_vec,phi_vec,source_num,tau_vec,SubCarrInd);  %paper
    [p_MUSIC_ss_non] = URA_ss_non_wfh(csi_trace_real, Mx, My, Fc,sub_freq_delta_,d, theta_vec,phi_vec,source_num,tau_vec,SubCarrInd);
% 
%     iters = 15;    % 这里都没有使用子载波数据，因为spice传统的就是没有使用。
%     [p_MUSIC_spice] = URA_ss_SPICE_wfh(Ry_ss1,Mx,My,d,wavelength,theta_vec_spice,phi_vec_spice,iters);   % 
%     [p_MUSIC_spice_N] = URA_SPICE_wfh(Ry_N,Mx,My,d,wavelength,theta_vec_spice,phi_vec_spice,iters);     % N都得用，且不平滑。  
% 
% 
%     [p_COLOC] = URA_COLOC_USTC(Ry,csi_y,Mx,My,d,wavelength,theta_vec_spice,phi_vec_spice,iters);
% 
% %     [p_MUSIC_tmusic_non] = URA_T_Music_non_wfh(csi_trace_real, Mx, My, Fc,sub_freq_delta_,d, theta_vec,phi_vec,source_num,tau_vec,SubCarrInd);
%     % I-SSMUSIC使用了 子载波，是做了平均。
%     [p_MUSIC_imusic_non] = URA_I_Music_non_wfh(csi_trace_real, Mx, My, Fc, sub_freq_delta_, d, theta_vec,phi_vec,source_num,tau_vec,SubCarrInd);
%     [p_MUSIC_imusic] = URA_I_Music_wfh(csi_trace_real, Mx, My, Fc,sub_freq_delta_,d, theta_vec,phi_vec,source_num,tau_vec,SubCarrInd);  % 最好！！！！！
% 
%     
%     [p_MUSIC_non_music] = URA_Music_non_wfh(csi_trace_real, Mx, My, Fc,sub_freq_delta_,d, theta_vec,phi_vec,source_num,tau_vec,SubCarrInd);
%     [p_MUSIC_music] = URA_Music_wfh(csi_trace_real, Mx, My, Fc,sub_freq_delta_,d, theta_vec,phi_vec,source_num,tau_vec,SubCarrInd);
%%
    figure
    s = surf(phi_vec,theta_vec,  10 * ((p_MUSIC_ss_non(:,:,1))));  % 左为行数，右为列数。
    s.EdgeColor = 'none';
    axis tight; 
    set(gca, 'FontSize', 12); 
    xlabel('$\phi$ [in deg]', 'Interpreter', 'latex', 'FontSize',15)
    ylabel('$\Theta$ [in deg]', 'Interpreter', 'latex', 'FontSize',15)
    title('$\tau$','Interpreter','latex');
    %%
    % figure
    % s = surf(phi_vec_spice,theta_vec_spice,  10 * ((p_COLOC(:,:))));  % 左为行数，右为列数。
    % s.EdgeColor = 'none';
    % axis tight; 
    % set(gca, 'FontSize', 12); 
    % xlabel('$\phi$ [in deg]', 'Interpreter', 'latex', 'FontSize',15)
    % ylabel('$\Theta$ [in deg]', 'Interpreter', 'latex', 'FontSize',15)
    % title('$\tau$','Interpreter','latex');

    % %% showing p_MUSIC
    % Mus_SR = p_SR(:,:);
    % [maxValue, linearIndex] = max(Mus_SR(:));
    % [row, col] = ind2sub(size(Mus_SR), linearIndex);
    % disp(['[ ',num2str(theta_vec_spice(row)),' , ',num2str(phi_vec_spice(col)),' ]'])
    % mark_p_SR(i,:) = [theta_vec_spice(row), phi_vec_spice(col)];


%     Mus_coloc = p_COLOC(:,:);
%     [maxValue, linearIndex] = max(Mus_coloc(:));
%     [row, col, tau_ind] = ind2sub(size(Mus_coloc), linearIndex);
%     disp(['[ ',num2str(theta_vec_spice(row)),' , ',num2str(phi_vec_spice(col)),' ]'])
%     mark_p_coloc(i,:) = [theta_vec_spice(row), phi_vec_spice(col)];
% 
