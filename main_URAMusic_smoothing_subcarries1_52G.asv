%     [maxValue, linearIndex] = max(p_MUSIC_ss(:));
%     [row, col, tau_ind] = ind2sub(size(p_MUSIC_ss), linearIndex);
%     disp(['[ ',num2str(theta_vec(row)),' , ',num2str(phi_vec(col)),' ]'])
%     mark_p_MUSIC_ss(i,:) = [theta_vec(row), phi_vec(col)];
% 
%     Mus = 10 * log10(squeeze(p_MUSIC_ss_non(:,:,:)));
%     [maxValue, linearIndex] = max(p_MUSIC_ss_non(:));
%     [row, col, tau_ind] = ind2sub(size(p_MUSIC_ss_non), linearIndex);
%     disp(['[ ',num2str(theta_vec(row)),' , ',num2str(phi_vec(col)),' ]'])
%     mark_p_MUSIC_ss_non(i,:) = [theta_vec(row), phi_vec(col)];
% 
% %     p_MUSIC_spice_ = reshape(p_MUSIC_spice(1:Q),[length(theta_var),length(phi_var)]);
% %     P2_S_norm = p_MUSIC_spice/max(p_MUSIC_spice,[],'all');
% %     figure
% %     imagesc(phi_vec_spice,theta_vec_spice, P2_S_norm);
%     Mus = 10 * log10(squeeze(p_MUSIC_spice(:,:)));
%     [maxValue, linearIndex] = max(Mus(:));
%     [row1, col1] = ind2sub(size(Mus), linearIndex);
%     disp(['[ ',num2str(theta_vec_spice(row1)),' , ',num2str(phi_vec_spice(col1)),' ]'])
